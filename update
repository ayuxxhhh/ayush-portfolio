    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // 1. Dynamic Typing Effect — fixed height, no layout shift
            const typeTarget = document.getElementById('dynamic-type');
            const words = ['narratives.', 'campaigns.', 'growth.', 'communities.', 'ROI.'];
            // Pre-measure the longest word to lock min-width
            const longestWord = words.reduce((a, b) => a.length > b.length ? a : b);
            typeTarget.style.minWidth = (longestWord.length * 0.55) + 'em';

            let wordIndex = 0;
            let charIndex = 0;
            let isDeleting = false;
            let typeSpeed = 100;

            function typeEffect() {
                const currentWord = words[wordIndex];
                if (isDeleting) {
                    typeTarget.textContent = currentWord.substring(0, charIndex - 1);
                    charIndex--;
                    typeSpeed = 50;
                } else {
                    typeTarget.textContent = currentWord.substring(0, charIndex + 1);
                    charIndex++;
                    typeSpeed = 150;
                }
                if (!isDeleting && charIndex === currentWord.length) {
                    isDeleting = true;
                    typeSpeed = 1500;
                } else if (isDeleting && charIndex === 0) {
                    isDeleting = false;
                    wordIndex = (wordIndex + 1) % words.length;
                    typeSpeed = 500;
                }
                setTimeout(typeEffect, typeSpeed);
            }
            setTimeout(typeEffect, 1000);

            // 2. Chart.js
            const ctx = document.getElementById('growthChart').getContext('2d');
            let gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(192, 86, 33, 0.5)');
            gradient.addColorStop(1, 'rgba(192, 86, 33, 0.0)');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Q1', 'Q2', 'Q3', 'Q4 (Digital Pivot)'],
                    datasets: [
                        { label: 'Website Traffic Growth (%)', data: [5, 12, 18, 40], borderColor: '#C05621', backgroundColor: gradient, borderWidth: 3, pointBackgroundColor: '#fff', pointBorderColor: '#C05621', pointBorderWidth: 2, pointRadius: 5, fill: true, tension: 0.4 },
                        { label: 'Lead-to-Enrollment Uplift (%)', data: [2, 5, 8, 15], borderColor: '#78716C', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], pointBackgroundColor: '#1C1917', pointBorderColor: '#78716C', pointRadius: 4, fill: false, tension: 0.4 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: '#A8A29E', font: { family: 'Inter', size: 12 } }, position: 'bottom' },
                        tooltip: { backgroundColor: '#1C1917', titleColor: '#FDFBF7', bodyColor: '#D6D3D1', borderColor: '#44403C', borderWidth: 1, padding: 12, callbacks: { label: c => c.dataset.label + ': ' + c.parsed.y + '%' } }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#292524', drawBorder: false }, ticks: { color: '#78716C', callback: v => v + '%' } },
                        x: { grid: { display: false, drawBorder: false }, ticks: { color: '#78716C' } }
                    },
                    interaction: { mode: 'index', intersect: false }
                }
            });

            // 3. Portfolio Filtering
            const filterBtns = document.querySelectorAll('.filter-btn');
            const portfolioItems = document.querySelectorAll('.portfolio-item');
            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterBtns.forEach(b => { b.classList.remove('active', 'bg-stone-900', 'text-white'); b.classList.add('text-stone-600'); });
                    btn.classList.add('active', 'bg-stone-900', 'text-white');
                    btn.classList.remove('text-stone-600');
                    const filterValue = btn.getAttribute('data-filter');
                    portfolioItems.forEach(item => {
                        if (filterValue === 'all' || item.getAttribute('data-category') === filterValue) {
                            item.style.display = 'block';
                            setTimeout(() => { item.style.opacity = '1'; item.style.transform = 'translateY(0)'; }, 50);
                        } else {
                            item.style.opacity = '0'; item.style.transform = 'translateY(20px)';
                            setTimeout(() => { item.style.display = 'none'; }, 300);
                        }
                    });
                });
            });

            // 4. Scroll Reveal
            const observer = new IntersectionObserver((entries, obs) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) { entry.target.classList.add('visible'); obs.unobserve(entry.target); }
                });
            }, { root: null, rootMargin: '0px', threshold: 0.15 });
            document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

            // 5. Inject full base64 photo after DOM ready (avoids huge inline attribute)
            const profilePhoto = document.getElementById('profile-photo');
            if (profilePhoto) {
                profilePhoto.src = 'data:image/jpeg;base64,';
            }
        });
    </script>
